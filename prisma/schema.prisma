// prisma/schema.prisma
// LedgerPro — PostgreSQL schema
// Double-entry ledger with full audit trail

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooled (PgBouncer, port 6543) for Prisma Client
  directUrl = env("DIRECT_URL")     // direct (port 5432) for migrations
}

// ─── AUTH & ORGANIZATION ────────────────────────────────────

model User {
  id                     String     @id @default(cuid())
  name                   String
  email                  String     @unique
  emailVerified          DateTime?
  emailVerificationToken String?
  passwordHash           String?    // bcrypt hash
  image                  String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  memberships            Membership[]
  auditLogs              AuditLog[]
  notifications          Notification[]
}

model Company {
  id               String             @id @default(cuid())
  name             String
  legalName        String?
  fiscalYearStart  DateTime           // e.g. 2025-01-01
  fiscalYearEnd    DateTime?          // e.g. 2025-12-31 (auto: +1y -1d, editable)
  businessType     BusinessType?      // sole_proprietor, partnership, corporation, etc.
  businessNumber   String?            // Canada: BN (9 digits)
  gstNumber        String?            // GST/HST registration number
  province         CanadianProvince?  // AB, BC, MB, NB, NL, NS, NT, NU, ON, PE, QC, SK, YT
  currency         String   @default("CAD")
  locale           String   @default("en-CA")
  timezone         String   @default("America/Edmonton")
  onboardingComplete Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships     Membership[]
  subscriptions   Subscription[]

  contacts         Contact[]
  invoices         Invoice[]
  bills            Bill[]
  accounts         FinancialAccount[]
  chartOfAccounts  ChartOfAccount[]
  transactions     Transaction[]
  journalEntries   JournalEntry[]
  importBatches    ImportBatch[]
  transferMatches  TransferMatch[]
  auditLogs           AuditLog[]
  budgets             Budget[]
  periodCloses        PeriodClose[]
  recurringTemplates  RecurringTemplate[]
  categorizationRules CategorizationRule[]
  reportTemplates     ReportTemplate[]
}

enum BusinessType {
  sole_proprietor
  partnership
  corporation
  nonprofit
  other
}

enum CanadianProvince {
  AB
  BC
  MB
  NB
  NL
  NS
  NT
  NU
  ON
  PE
  QC
  SK
  YT
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(viewer)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId, role])
}

enum UserRole {
  owner
  admin
  bookkeeper
  viewer
}

// ─── SUBSCRIPTION & PLANS ───────────────────────────────────

model Plan {
  id            String   @id @default(cuid())
  name          String   // "Free Trial", "Basic", "Pro", "Enterprise"
  stripePriceId String?
  monthlyPrice  Decimal  @db.Decimal(10, 2)
  annualPrice   Decimal  @db.Decimal(10, 2)

  maxUsers        Int     @default(1)
  maxCompanies    Int     @default(1)
  maxTransactions Int     @default(500)
  maxBankAccounts Int     @default(1)
  csvExport       Boolean @default(true)
  pdfReports      Boolean @default(false)
  bankFeeds       Boolean @default(false)
  customReports   Boolean @default(false)
  prioritySupport Boolean @default(false)
  whiteLabel      Boolean @default(false)

  features        Json?

  subscriptions   Subscription[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Subscription {
  id              String             @id @default(cuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId          String
  plan            Plan               @relation(fields: [planId], references: [id])

  status          SubscriptionStatus @default(trialing)
  trialEndsAt     DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  canceledAt      DateTime?

  stripeSubscriptionId String?
  stripeCustomerId     String?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([companyId])
  @@index([status])
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

// ─── CHART OF ACCOUNTS (GL) ─────────────────────────────────

model ChartOfAccount {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])

  code        String
  name        String
  type        GLType
  detailType  String?
  parentCode  String?
  description String?
  balance     Decimal  @default(0) @db.Decimal(14, 2)
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions        Transaction[]        @relation("TransactionCategory")
  billLines           BillLineItem[]        @relation("BillLineCategory")
  lineItems           InvoiceLineItem[]     @relation("InvoiceLineCategory")
  categorizationRules CategorizationRule[]

  @@unique([companyId, code])
  @@index([companyId, type])
  @@index([parentCode])
}

enum GLType {
  asset
  liability
  equity
  income
  expense
}

// ─── FINANCIAL ACCOUNTS (bank / credit card / clearing) ─────

model FinancialAccount {
  id             String       @id @default(cuid())
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id])

  name           String
  mask           String?
  kind           AccountKind
  currentBalance Decimal      @default(0) @db.Decimal(14, 2)
  glAccountCode  String?      // e.g. "1010" — manual reference to ChartOfAccount.code

  syncStatus      SyncStatus @default(manual)
  lastSyncedAt    DateTime?
  plaidItemId     String?
  plaidAccessToken String?

  displayColor   String?
  logoInitials   String?
  isActive       Boolean     @default(true)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transactions   Transaction[]  @relation("TxAccount")
  imports        ImportBatch[]
  bills          Bill[]         @relation("BillPaymentAccount")
  columnMappings ColumnMapping[]
  invoicePayments Invoice[]     @relation("InvoicePaymentAccount")

  @@index([companyId])
}

enum AccountKind {
  checking
  savings
  creditcard
  payoutclearing
}

enum SyncStatus {
  manual
  connected
  error
  paused
}

// ─── COLUMN MAPPING PROFILES ────────────────────────────────

model ColumnMapping {
  id                  String           @id @default(cuid())
  financialAccountId  String
  account             FinancialAccount @relation(fields: [financialAccountId], references: [id])

  profileName         String?
  dateColumn          String
  descriptionColumn   String
  amountColumn        String?
  debitColumn         String?
  creditColumn        String?
  balanceColumn       String?
  signDirection       SignDirection    @default(normal)
  skipRows            Int              @default(0)
  dateFormat          String           @default("yyyy-MM-dd")

  createdAt           DateTime         @default(now())

  importBatches       ImportBatch[]

  @@unique([financialAccountId, profileName])
}

enum SignDirection {
  normal
  inverted
}

// ─── TRANSACTIONS (bank / card line items) ──────────────────

model Transaction {
  id                 String        @id @default(cuid())
  companyId          String
  company            Company       @relation(fields: [companyId], references: [id])

  financialAccountId String
  account            FinancialAccount @relation("TxAccount", fields: [financialAccountId], references: [id])

  date               DateTime
  description        String
  merchant           String?
  rawStatementText   String?
  amount             Decimal       @db.Decimal(14, 2)
  currency           String        @default("CAD")

  categoryId         String?
  category           ChartOfAccount? @relation("TransactionCategory", fields: [categoryId], references: [id])
  suggestedCategoryId String?

  status             TxStatus      @default(toreview)
  excludeReason      String?
  matchRef           String?
  reconciledAt       DateTime?
  reconciledBy       String?
  voidedAt           DateTime?
  voidedBy           String?

  importBatchId      String?
  importBatch        ImportBatch?   @relation(fields: [importBatchId], references: [id])
  source             TxSource      @default(manual)

  transferMatch      TransferMatch? @relation("Transfers")
  inflowTransferMatch TransferMatch? @relation("TransferInflow")
  transferMatchId    String?        // set by transfer matching engine

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([companyId, financialAccountId, date])
  @@index([status])
  @@index([categoryId])
  @@index([importBatchId])
}

enum TxStatus {
  toreview
  categorized
  excluded
  transfer
  reconciled
  voided
}

enum TxSource {
  feed
  csv
  ofx
  pdf
  manual
}

// ─── TRANSFER MATCHING ──────────────────────────────────────

model TransferMatch {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])

  outflowTxId     String        @unique
  inflowTxId      String        @unique
  amount          Decimal       @db.Decimal(14, 2)

  matchDate       DateTime
  matchConfidence Decimal       @default(1.0) @db.Decimal(3, 2)
  confirmed       Boolean       @default(false)
  confirmedAt     DateTime?
  confirmedBy     String?

  journalEntryId  String?       @unique
  journalEntry    JournalEntry?

  createdAt       DateTime      @default(now())

  outflowTx       Transaction   @relation("Transfers", fields: [outflowTxId], references: [id])
  inflowTx        Transaction   @relation("TransferInflow", fields: [inflowTxId], references: [id])

  @@index([companyId, confirmed])
}

// ─── CONTACTS ───────────────────────────────────────────────

model Contact {
  id                String        @id @default(cuid())
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])

  name              String
  companyName       String?
  type              ContactType
  email             String?
  phone             String?
  address           String?
  outstandingBalance Decimal      @default(0) @db.Decimal(14, 2)
  status            ContactStatus @default(active)
  notes             String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  invoices          Invoice[]     @relation("InvoiceCustomer")
  bills             Bill[]        @relation("BillVendor")

  @@index([companyId, type])
  @@index([companyId, status])
}

enum ContactType {
  customer
  supplier
}

enum ContactStatus {
  active
  inactive
}

// ─── INVOICES ──────────────────────────────────────────────

model Invoice {
  id              String      @id
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])

  customerId      String
  customer        Contact     @relation("InvoiceCustomer", fields: [customerId], references: [id])

  issueDate       DateTime
  dueDate         DateTime
  terms           String?
  currency        String      @default("CAD")

  subtotal        Decimal     @db.Decimal(14, 2)
  taxRate         Decimal?    @default(0) @db.Decimal(5, 3)
  taxAmount       Decimal     @default(0) @db.Decimal(14, 2)
  total           Decimal     @db.Decimal(14, 2)

  status          InvoiceStatus @default(draft)
  sentAt          DateTime?
  paidAt          DateTime?
  paidAmount      Decimal     @default(0) @db.Decimal(14, 2)

  notes           String?
  paymentAccountId String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  paymentAccount  FinancialAccount? @relation("InvoicePaymentAccount", fields: [paymentAccountId], references: [id])
  lineItems       InvoiceLineItem[]

  @@index([companyId, customerId])
  @@index([companyId, status])
  @@index([issueDate])
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  void
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(14, 2)
  amount      Decimal  @db.Decimal(14, 2)
  categoryId  String?
  category    ChartOfAccount? @relation("InvoiceLineCategory", fields: [categoryId], references: [id])

  sortOrder   Int      @default(0)
}

// ─── BILLS & EXPENSES ──────────────────────────────────────

model Bill {
  id              String      @id
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])

  kind            BillKind
  vendorId        String
  vendor          Contact     @relation("BillVendor", fields: [vendorId], references: [id])

  billDate        DateTime
  dueDate         DateTime?
  terms           String?
  referenceNo     String?

  subtotal        Decimal     @db.Decimal(14, 2)
  taxRate         Decimal?    @default(0) @db.Decimal(5, 3)
  taxAmount       Decimal     @default(0) @db.Decimal(14, 2)
  total           Decimal     @db.Decimal(14, 2)
  currency        String      @default("CAD")

  status          BillStatus  @default(draft)

  paymentAccountId String?
  paidAt          DateTime?
  paidAmount      Decimal     @default(0) @db.Decimal(14, 2)

  notes           String?
  attachments     String[]    @default([])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  paymentAccount  FinancialAccount? @relation("BillPaymentAccount", fields: [paymentAccountId], references: [id])
  lineItems       BillLineItem[]

  @@index([companyId, vendorId])
  @@index([companyId, kind])
  @@index([companyId, status])
}

enum BillKind {
  bill
  expense
}

enum BillStatus {
  draft
  open
  paid
  overdue
  void
}

model BillLineItem {
  id          String   @id @default(cuid())
  billId      String
  bill        Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  description String
  amount      Decimal  @db.Decimal(14, 2)
  categoryId  String?
  category    ChartOfAccount? @relation("BillLineCategory", fields: [categoryId], references: [id])

  sortOrder   Int      @default(0)
}

// ─── DOUBLE-ENTRY JOURNAL ──────────────────────────────────

model JournalEntry {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])

  entryDate       DateTime
  description     String
  sourceType      JournalSource
  sourceId        String?

  lines           JournalLine[]

  transferMatchId String?       @unique
  transferMatch   TransferMatch? @relation(fields: [transferMatchId], references: [id])

  // Void/reversal trail: voiding never deletes a posted entry — it links a reversing entry instead.
  voidedAt        DateTime?
  voidedBy        String?
  reversalOfId    String?       @unique
  reversalOf      JournalEntry? @relation("EntryReversal", fields: [reversalOfId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reversedBy      JournalEntry? @relation("EntryReversal")

  createdBy       String?
  createdAt       DateTime      @default(now())

  @@index([companyId, entryDate])
  @@index([sourceType, sourceId])
}

enum JournalSource {
  invoice
  bill
  payment
  transfer
  manual
}

model JournalLine {
  id              String        @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  glAccountCode   String        // e.g. "1010" — manual reference to ChartOfAccount.code
  description     String?
  debit           Decimal       @default(0) @db.Decimal(14, 2)
  credit          Decimal       @default(0) @db.Decimal(14, 2)

  @@index([glAccountCode])
}

// ─── IMPORT BATCHES ────────────────────────────────────────

model ImportBatch {
  id                   String           @id @default(cuid())
  companyId            String
  company              Company          @relation(fields: [companyId], references: [id])

  financialAccountId   String
  account              FinancialAccount @relation(fields: [financialAccountId], references: [id])

  fileName             String
  fileType             TxSource
  fileSize             Int?

  rowsParsed           Int
  rowsImported         Int
  duplicatesFound      Int              @default(0)
  dateRangeStart       DateTime?
  dateRangeEnd         DateTime?

  columnMappingId      String?
  columnMapping        ColumnMapping?   @relation(fields: [columnMappingId], references: [id])
  mappingConfirmed     Boolean          @default(false)
  importConfirmed      Boolean          @default(false)

  errors               Json?

  status               ImportStatus     @default(draft)

  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  transactions         Transaction[]

  @@index([companyId, financialAccountId])
  @@index([status])
}

enum ImportStatus {
  draft
  mapped
  confirmed
  imported
  error
}

// ─── AUDIT LOG ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  action      String      // e.g. "invoice.create", "transaction.categorize"
  entityType  String      // "invoice", "transaction", "contact", "journal_entry"
  entityId    String?
  changes     Json?       // { before, after } diff
  metadata    Json?       // IP, user agent, etc.

  createdAt   DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
}

// ─── BUDGETS ───────────────────────────────────────────────

model Budget {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])

  name          String
  fiscalYear    Int
  period        BudgetPeriod // monthly, quarterly, annual

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  lines         BudgetLine[]

  @@unique([companyId, name, fiscalYear])
}

model BudgetLine {
  id            String   @id @default(cuid())
  budgetId      String
  budget        Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  glAccountCode String
  amount        Decimal  @db.Decimal(14, 2)
  period        String?  // e.g. "2026-01" for monthly

  @@index([glAccountCode])
}

enum BudgetPeriod {
  monthly
  quarterly
  annual
}

// ─── PERIOD CLOSE ──────────────────────────────────────────

model PeriodClose {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])

  periodStart   DateTime
  periodEnd     DateTime
  closedBy      String?
  closedAt      DateTime?

  status        CloseStatus @default(draft)
  notes         String?

  createdAt     DateTime    @default(now())

  @@unique([companyId, periodStart, periodEnd])
}

enum CloseStatus {
  draft
  closed
  reopened
}

// ─── NOTIFICATIONS ─────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId   String

  type        NotificationType
  title       String
  body        String
  actionUrl   String?
  read        Boolean          @default(false)

  createdAt   DateTime         @default(now())

  @@index([userId, read])
  @@index([companyId, createdAt])
}

enum NotificationType {
  invoice_overdue
  bill_due
  reconciliation_needed
  import_complete
  transfer_detected
  period_close_reminder
  subscription_expiring
  member_joined
  system
}

// ─── CANADIAN TAX RATES ──────────────────────────────────────

model TaxRate {
  id            String           @id @default(cuid())
  province      CanadianProvince @unique
  provinceName  String           // "Alberta", "British Columbia", etc.
  gst           Decimal          @default(5.00) @db.Decimal(5, 3)   // Federal GST (5% everywhere)
  hst           Decimal          @default(0) @db.Decimal(5, 3)      // Harmonized (replaces GST+PST in some provinces)
  pst           Decimal          @default(0) @db.Decimal(5, 3)      // Provincial sales tax (separate from GST)
  totalSalesTax Decimal          @db.Decimal(5, 3)                  // Effective total sales tax rate
  label         String                                               // "5% GST", "13% HST", "5% GST + 7% PST"

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// ─── RECURRING TRANSACTIONS ──────────────────────────────────

model RecurringTemplate {
  id            String          @id @default(cuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name          String          // "Monthly Rent", "Annual SaaS"
  description   String?
  frequency     RecurringFrequency // weekly, monthly, quarterly, annual
  nextPostDate  DateTime        // next scheduled posting date
  endDate       DateTime?       // optional end date
  active        Boolean         @default(true)

  // Template for the journal entry
  sourceType    JournalSource   @default(manual)
  lines         RecurringLine[]

  lastPostedAt  DateTime?
  timesPosted   Int             @default(0)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model RecurringLine {
  id            String          @id @default(cuid())
  templateId    String
  template      RecurringTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  glAccountCode String
  description   String?
  debit         Decimal         @default(0) @db.Decimal(14, 2)
  credit        Decimal         @default(0) @db.Decimal(14, 2)
  sortOrder     Int             @default(0)
}

enum RecurringFrequency {
  weekly
  monthly
  quarterly
  annual
}

// ─── AI CATEGORIZATION RULES ─────────────────────────────────

model CategorizationRule {
  id            String          @id @default(cuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name          String          // "AWS charges", "Google Workspace"
  pattern       String          // regex or merchant name
  patternType   RulePatternType // merchant_match, description_contains, amount_range
  categoryId    String
  category      ChartOfAccount  @relation(fields: [categoryId], references: [id])

  minAmount     Decimal?        @db.Decimal(14, 2)  // for amount_range
  maxAmount     Decimal?        @db.Decimal(14, 2)
  priority      Int             @default(0)          // higher = checked first
  active        Boolean         @default(true)

  matchCount    Int             @default(0)          // how many times matched
  lastMatchedAt DateTime?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum RulePatternType {
  merchant_match
  description_contains
  amount_range
  regex
}

// ─── CUSTOM REPORT TEMPLATES ──────────────────────────────────

model ReportTemplate {
  id            String          @id @default(cuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name          String          // "Monthly P&L by Department"
  reportType    String          // profit_loss, balance_sheet, custom, etc.
  config        Json            // { accounts: [...], grouping, columns, period }
  isPublic      Boolean         @default(false)    // visible to all company members

  createdBy     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}
